---
---

<footer class="footer">
  <div class="container footer__inner">
    <img src="/logo/mark-reversed.svg" alt="Angelo Baleno mark" width="30" height="31" class="footer__mark" />
    <p class="footer__sig">In a flash<span class="dot" aria-hidden="true"></span></p>
    <p class="label footer__meta">Angelo&nbsp;Baleno &nbsp;·&nbsp; Est.&nbsp;2020</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--hairline-on-ink);
    padding-block: clamp(2.75rem, 7vh, 4.5rem);
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.1rem;
  }

  .footer__mark {
    width: 30px;
    height: auto;
  }

  .footer__sig {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 1.1rem;
    color: var(--bone);
  }

  .footer__sig .dot {
    display: inline-block;
    width: 0.3em;
    height: 0.3em;
    border-radius: 50%;
    background: var(--brass);
    margin-left: 0.16em;
    vertical-align: baseline;
  }

  .footer__meta {
    color: var(--steel);
  }
</style>
