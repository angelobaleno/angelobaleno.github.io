---
---

<section class="hero" id="top">
  <div class="hero__light" aria-hidden="true"></div>
  <div class="hero__shaft" aria-hidden="true"></div>
  <canvas class="hero__dust" aria-hidden="true"></canvas>
  <div class="hero__vignette" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__frame">

      <img
        src="/logo/mark-reversed.svg"
        alt="Angelo Baleno mark"
        class="hero__mark"
        width="84"
        height="87"
      />

      <h1 class="hero__headline">
        <span class="line line--mid"><span class="line__inner">Make it</span></span>
        <span class="line line--max"><span class="line__inner">Match</span></span>
        <span class="line line--mid"><span class="line__inner">the work<span class="dot" aria-hidden="true"></span></span></span>
      </h1>

      <div class="hero__threshold" aria-hidden="true"></div>

      <p class="hero__support">
        Design and development, one craft. I build sites for athletes and the
        people around the game — sites that match the work behind them.
      </p>

    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100svh - 64px);
    display: flex;
    overflow: hidden;
  }

  /* ---- Environmental light: warm bloom entering the shadow ---- */
  .hero__light {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(52% 42% at 50% 40%, rgba(240, 226, 194, 0.16), transparent 70%),
      linear-gradient(to bottom, rgba(240, 226, 194, 0.05), transparent 44%);
    opacity: 0;
    animation:
      light-enter 2.8s ease-in-out 0.15s forwards,
      light-drift 13s ease-in-out 0s infinite alternate;
  }

  /* a faint shaft of light, slowly sweeping — part of the drifting light */
  .hero__shaft {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: linear-gradient(102deg, transparent 40%, rgba(240, 226, 194, 0.085) 50%, transparent 60%);
    mix-blend-mode: screen;
    opacity: 0;
    animation:
      light-enter 3s ease-in-out 0.35s forwards,
      shaft-drift 18s ease-in-out 0s infinite alternate;
  }

  /* dust motes drifting in the light — drawn on canvas by the script below */
  .hero__dust {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    display: block;
    opacity: 0;
    animation: light-enter 2.6s ease-in-out 0.5s forwards;
  }

  /* Vignette: bright pool in the center, deep shadow to the edges (the drama),
     and the bottom resolves to solid ink so the hero DISSOLVES into the next
     section instead of cutting off at a hard line. */
  .hero__vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(to bottom, transparent 56%, var(--ink) 95%),
      radial-gradient(82% 68% at 50% 40%, transparent 38%, rgba(6, 6, 6, 0.62) 100%);
  }

  .hero__inner {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: clamp(3rem, 8vh, 6rem);
  }

  /* ---- The facade: centered, axial, framed by the doorway jambs ---- */
  .hero__frame {
    position: relative;
    max-width: 62rem;
    margin-inline: auto;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-inline: clamp(1.5rem, 5vw, 4rem);
  }

  /* jamb hairlines — the vertical structure you look between */
  .hero__frame::before,
  .hero__frame::after {
    content: "";
    position: absolute;
    top: 0.5rem;
    bottom: 0.5rem;
    width: 1px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--hairline-on-ink) 14%,
      var(--hairline-on-ink) 86%,
      transparent
    );
    transform: scaleY(0);
    transform-origin: top;
    animation: jamb-rise 1.1s var(--ease-settle) 0.1s forwards;
  }
  .hero__frame::before { left: 0; }
  .hero__frame::after  { right: 0; }

  /* ---- Mark: the keystone, crowning the facade ---- */
  .hero__mark {
    width: clamp(64px, 6.5vw, 88px);
    height: auto;
    margin-bottom: clamp(1.75rem, 4.5vh, 3rem);
    opacity: 0;
    transform: translateY(-8px) scale(0.92);
    animation: mark-set 0.9s var(--ease-settle) 0.1s forwards;
  }

  /* ---- Monumental statement — a poster lockup, set like carved stone ---- */
  .hero__headline {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    color: var(--bone);
    display: flex;
    flex-direction: column;
    align-items: center;
    line-height: 1;
    letter-spacing: 0.012em;
    /* one uniform gap between the trimmed cap-blocks below — equal by construction */
    gap: clamp(0.4rem, 1vw, 0.9rem);
  }

  /* hierarchy: MATCH is the punch, the two flanks quieter */
  .line--mid { font-size: clamp(2.5rem, 8vw, 6.75rem); }
  .line--max {
    font-size: clamp(4.25rem, 16.5vw, 13.5rem);
    letter-spacing: 0.005em;
  }

  .line {
    display: block;
  }

  /* THE REAL FIX: trim each line's box to the actual CAPS (top) and baseline
     (bottom). The font's invisible leading/descender space — the "hitbox" that
     threw the rhythm off — is removed, so vertical spacing is measured from the
     letterforms, not the line-box. Equal gap in, equal gap out. */
  .line__inner {
    display: block;
    opacity: 0;
    transform: translateY(0.4em);
    text-box-trim: trim-both;
    text-box-edge: cap alphabetic;
    text-box: trim-both cap alphabetic;
  }

  /* The full stop — a round brass inlay, not Tusker's square glyph. The one flex. */
  .dot {
    display: inline-block;
    width: 0.13em;
    height: 0.13em;
    border-radius: 50%;
    background: var(--brass);
    vertical-align: baseline;
    margin-left: 0.1em;
  }

  .hero__threshold {
    width: clamp(4.5rem, 12vw, 9rem);
    height: 1px;
    background: var(--hairline-on-ink);
    margin-block: clamp(2rem, 5vh, 3.25rem) clamp(1.5rem, 3.5vh, 2.25rem);
    transform: scaleX(0);
    animation: rule-draw 0.8s var(--ease-settle) 0.85s forwards;
  }

  .hero__support {
    max-width: 46ch;
    color: var(--muted-on-ink);
    font-size: clamp(1rem, 1.4vw, 1.1875rem);
    opacity: 0;
    animation: fade-set 0.7s ease-out 1s forwards;
  }

  /* ---------- Load sequence: entering the temple. Slow, weighty, ends still. ---------- */
  .line:nth-child(1) .line__inner { animation: line-set 0.85s var(--ease-settle) 0.3s forwards; }
  .line:nth-child(2) .line__inner { animation: line-set 0.9s var(--ease-settle) 0.42s forwards; }
  .line:nth-child(3) .line__inner { animation: line-set 0.85s var(--ease-settle) 0.56s forwards; }

  @keyframes line-set {
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes light-enter {
    to { opacity: 1; }
  }

  @keyframes light-drift {
    from { transform: translate(-5%, -3%) scale(1.02); }
    to   { transform: translate(5%, 4%) scale(1.2); }
  }

  @keyframes shaft-drift {
    from { transform: translateX(-9%); }
    to   { transform: translateX(9%); }
  }

  @keyframes jamb-rise {
    to { transform: scaleY(1); }
  }

  @keyframes rule-draw {
    to { transform: scaleX(1); }
  }

  @keyframes mark-set {
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes fade-set {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__light,
    .hero__shaft,
    .hero__dust,
    .hero__frame::before,
    .hero__frame::after,
    .hero__mark,
    .line .line__inner,
    .hero__threshold,
    .hero__support {
      animation: none;
      transform: none;
      opacity: 1;
    }
  }
</style>

<script>
  // Dust motes drifting in the light. Sparse and slow — never a particle effect.
  const c = document.querySelector('.hero__dust');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (c instanceof HTMLCanvasElement && !reduce) {
    const ctx = c.getContext('2d');
    let W = 0, H = 0, dpr = 1, parts = [];
    const makeP = () => ({
      x: Math.random() * W,
      y: Math.random() * H,
      r: Math.random() * 1.8 + 0.5,
      vx: (Math.random() - 0.5) * 0.17,
      vy: -(Math.random() * 0.22 + 0.07),
      a: Math.random() * 0.55 + 0.28,
      tw: Math.random() * Math.PI * 2,
    });
    const size = () => {
      const rect = c.getBoundingClientRect();
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = rect.width; H = rect.height;
      c.width = W * dpr; c.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      parts = Array.from({ length: 50 }, makeP);
    };
    const loop = () => {
      ctx.clearRect(0, 0, W, H);
      for (const p of parts) {
        p.x += p.vx; p.y += p.vy; p.tw += 0.032;
        if (p.y < -6) { p.y = H + 6; p.x = Math.random() * W; }
        if (p.x < -6) p.x = W + 6;
        if (p.x > W + 6) p.x = -6;
        const dx = (p.x - W / 2) / (W / 2);
        const dy = (p.y - H * 0.42) / (H * 0.5);
        const light = Math.max(0, 1 - Math.sqrt(dx * dx + dy * dy));
        const alpha = p.a * (0.22 + 0.9 * light) * (0.7 + 0.3 * Math.sin(p.tw));
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, 7);
        ctx.fillStyle = 'rgba(240,226,194,' + alpha.toFixed(3) + ')';
        ctx.fill();
      }
      requestAnimationFrame(loop);
    };
    size();
    window.addEventListener('resize', size);
    requestAnimationFrame(loop);
  }
</script>
