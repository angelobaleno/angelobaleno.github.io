<section class="section contact" id="contact">
  <div class="container">
    <p class="label reveal">Contact</p>
    <h2 class="contact__line reveal">
      Let&rsquo;s get to work<span class="dot">.</span>
    </h2>
    <p class="contact__prompt reveal">Tell me what you&rsquo;re building.</p>
    <div class="contact__row reveal">
      <span class="label">Email</span>
      <a class="contact__email" href="mailto:angelojbaleno@gmail.com">angelojbaleno@gmail.com</a>
    </div>
  </div>
</section>

<style>
  .contact__line {
    font-weight: 600;
    font-size: clamp(1.75rem, 4vw, 3rem);
    letter-spacing: -0.01em;
    line-height: 1.15;
    max-width: 20ch;
    margin-top: 0.75rem;
  }

  .contact__prompt {
    margin-top: 1.1rem;
    color: var(--muted-on-ink);
    font-size: clamp(1rem, 1.7vw, 1.3rem);
    max-width: 36ch;
  }

  .contact__row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: clamp(1.75rem, 4vh, 2.5rem);
  }

  .contact__email {
    font-weight: 600;
    font-size: clamp(1.125rem, 2.4vw, 1.625rem);
    letter-spacing: -0.005em;
    border-bottom: 1px solid var(--hairline-on-ink);
    align-self: flex-start;
    padding-bottom: 0.125rem;
    transition: border-color 0.2s ease;
  }

  .contact__email:hover,
  .contact__email:focus-visible {
    border-color: var(--brass);
  }
</style>
