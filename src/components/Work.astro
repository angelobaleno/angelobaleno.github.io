---
interface Project {
  num: string;
  title: string;
  blurb: string;
  meta: string;
  status: string;
  img: string;
  href: string;
}

const projects: Project[] = [
  {
    num: '01',
    title: 'The Recruiting Platform',
    img: '/work/athlete.webp',
    blurb:
      'A platform of recruiting sites for athletes, themed per athlete. First live: a DB recruit, Class of 2027.',
    meta: 'Platform · Astro · SSR · Supabase',
    status: 'Live',
    href: 'https://tyler-baleno-site.vercel.app/',
  },
  {
    num: '02',
    title: 'Brian Baleno',
    img: '/work/brian.webp',
    blurb:
      'A warm, literary single-scroll site for an author, with a page for each book.',
    meta: 'Author site · Astro · Static',
    status: 'Live',
    href: 'https://angelobaleno.github.io/brian-baleno-site/',
  },
  {
    num: '03',
    title: "Webb's World of Fitness",
    img: '/work/webbs.webp',
    blurb:
      'A charcoal-and-gold single-scroll site for a Pittsburgh gym.',
    meta: 'Gym site · Astro · Static',
    status: 'Live',
    href: 'https://angelobaleno.github.io/webbs-world-of-fitness/',
  },
];
---

<section class="section work" id="work">
  <div class="container">
    <div class="sechead reveal">
      <div class="sechead__main">
        <p class="label">Work</p>
        <h2 class="work__title">The proof<span class="dot">.</span></h2>
      </div>
      <p class="label sechead__aside">03 sites — all live</p>
    </div>

    <div class="plates">
      {projects.map((p) => (
        <a class="plate reveal" href={p.href} target="_blank" rel="noopener noreferrer" aria-label={`${p.title} — open the live site`}>
          <div class="plate__media">
            <img class="plate__shot" src={p.img} alt={`${p.title} screenshot`} loading="lazy" decoding="async" width="1600" height="850" />
            <span class="plate__num" aria-hidden="true">{p.num}</span>
            <span class="label plate__visit" aria-hidden="true">Visit ↗</span>
          </div>
          <div class="plate__row">
            <h3 class="plate__name">{p.title}</h3>
            <p class="label plate__meta">{p.meta} — <span class="plate__status">{p.status}</span></p>
          </div>
          <p class="plate__blurb">{p.blurb}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .work__title {
    font-weight: 600;
    font-size: var(--title-section);
    letter-spacing: -0.015em;
    line-height: 1.05;
  }

  /* ---- The gallery: each site is a full-width plate, hung like work ---- */
  .plates {
    display: flex;
    flex-direction: column;
    gap: clamp(4rem, 9vh, 6.5rem);
  }

  .plate {
    display: block;
    color: inherit;
  }

  .plate__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 1px solid var(--hairline-on-ink);
    background: var(--ink);
    transition: border-color 0.2s var(--ease-cut);
  }

  .plate:hover .plate__media,
  .plate:focus-visible .plate__media {
    border-color: var(--steel);
  }

  /* screenshot sits crisp — no forced zoom, no drift. The card holds still;
     only the accent cues shift on hover. */
  .plate__shot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  /* scrim so the index number and visit cue hold over any screenshot */
  .plate__media::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 34%;
    background: linear-gradient(to bottom, rgba(20, 20, 20, 0.5), transparent);
    pointer-events: none;
  }

  .plate__num {
    position: absolute;
    top: 1rem;
    left: 1.25rem;
    z-index: 1;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.4rem;
    line-height: 1;
    color: var(--bone);
    transition: color 0.15s var(--ease-cut);
  }

  .plate:hover .plate__num,
  .plate:focus-visible .plate__num {
    color: var(--brass);
  }

  .plate__visit {
    position: absolute;
    top: 1.375rem;
    right: 1.25rem;
    z-index: 1;
    color: var(--bone);
    opacity: 0;
    transition: opacity 0.15s var(--ease-cut);
  }

  .plate:hover .plate__visit,
  .plate:focus-visible .plate__visit {
    opacity: 1;
  }

  /* editorial title line under the plate */
  .plate__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem 0 1rem;
    border-bottom: 1px solid var(--hairline-on-ink);
  }

  .plate__name {
    font-weight: 600;
    font-size: clamp(1.375rem, 2.4vw, 1.875rem);
    letter-spacing: -0.01em;
    line-height: 1.15;
  }

  .plate__meta {
    text-align: right;
    white-space: nowrap;
  }

  .plate__status {
    color: var(--brass);
  }

  .plate__blurb {
    margin-top: 0.9rem;
    color: var(--muted-on-ink);
    font-size: 0.9875rem;
    max-width: 64ch;
  }

  @media (max-width: 700px) {
    .plate__media { aspect-ratio: 16 / 10; }
    .plate__row {
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-start;
    }
    .plate__meta { text-align: left; white-space: normal; }
  }
</style>
