---
interface Project {
  num: string;
  title: string;
  blurb: string;
  tags: string[];
  status: string;
  img: string;
  href: string;
  wide?: boolean;
}

const projects: Project[] = [
  {
    num: '01',
    title: 'Athlete Sites',
    img: '/work/athlete.webp',
    blurb:
      'A platform of recruiting sites for athletes — each one built to look recruited, not templated. Themed per athlete. First live: a DB recruit, Class of 2027.',
    tags: ['Platform', 'Astro', 'SSR'],
    status: 'Live',
    href: 'https://tyler-baleno-site.vercel.app/',
    wide: true,
  },
  {
    num: '02',
    title: 'Brian Baleno — Author Site',
    img: '/work/brian.webp',
    blurb:
      'A warm, literary single-scroll site for an author, with a page for each book.',
    tags: ['Web', 'Astro'],
    status: 'Live',
    href: 'https://angelobaleno.github.io/brian-baleno-site/',
  },
  {
    num: '03',
    title: "Webb's World of Fitness",
    img: '/work/webbs.webp',
    blurb:
      'A charcoal-and-gold single-scroll site for a Pittsburgh gym.',
    tags: ['Web', 'Astro'],
    status: 'Live',
    href: 'https://angelobaleno.github.io/webbs-world-of-fitness/',
  },
];
---

<section class="section work" id="work">
  <div class="container">
    <div class="work__head reveal">
      <p class="label">Work</p>
      <h2 class="work__title">The proof<span class="dot">.</span></h2>
    </div>

    <div class="cards">
      {projects.map((p) => (
        <a class={`card reveal${p.wide ? ' card--wide' : ''}`} href={p.href} target="_blank" rel="noopener noreferrer" aria-label={`${p.title} — open the live site`}>
          <div class="card__media">
            <img class="card__shot" src={p.img} alt={`${p.title} screenshot`} loading="lazy" decoding="async" width="1400" height="875" />
            <span class="card__num">{p.num}</span>
          </div>
          <div class="card__body">
            <div class="card__row">
              <h3 class="card__name">{p.title}</h3>
              <span class="label card__status">{p.status}</span>
            </div>
            <p class="card__blurb">{p.blurb}</p>
            <ul class="card__tags" role="list">
              {p.tags.map((t) => (
                <li class="label">{t}</li>
              ))}
            </ul>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .work__head {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: clamp(2.5rem, 6vh, 4rem);
  }

  .work__title {
    font-weight: 600;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  .cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .card--wide {
    grid-column: 1 / -1;
  }

  /* centerpiece: let the featured shot sit a touch wider than the 16:10 cards */
  .card--wide .card__media {
    aspect-ratio: 16 / 9;
  }

  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--hairline-on-ink);
    background: var(--ink);
    color: inherit;
    transition: border-color 0.25s ease, transform 0.25s var(--ease-settle);
  }

  .card:hover,
  .card:focus-visible {
    border-color: var(--steel);
    transform: translateY(-3px);
  }

  .card__media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    border-bottom: 1px solid var(--brass);
  }

  .card__shot {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
    transition: transform 0.5s var(--ease-settle);
  }

  .card:hover .card__shot,
  .card:focus-visible .card__shot {
    transform: scale(1.04);
  }

  /* scrim so the index number stays legible over any screenshot */
  .card__media::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 44%;
    background: linear-gradient(to bottom, rgba(20, 20, 20, 0.55), transparent);
    pointer-events: none;
  }

  .card__num {
    position: absolute;
    top: 0.75rem;
    left: 1rem;
    z-index: 1;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.9rem;
    line-height: 1;
    color: var(--bone);
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem 1rem 1.375rem;
    flex: 1;
  }

  .card__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .card__name {
    font-weight: 600;
    font-size: 1.125rem;
    letter-spacing: -0.005em;
    line-height: 1.3;
  }

  .card__status {
    color: var(--brass);
    white-space: nowrap;
  }

  .card__blurb {
    color: var(--muted-on-ink);
    font-size: 0.9375rem;
    flex: 1;
  }

  .card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media (max-width: 900px) {
    .cards { grid-template-columns: 1fr; }
  }
</style>
