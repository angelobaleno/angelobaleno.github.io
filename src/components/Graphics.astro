---
interface Graphic {
  src: string;
  alt: string;
  name: string;
  type: string;
  wide?: boolean;
}

const graphics: Graphic[] = [
  {
    src: '/graphics/finalfull.webp',
    alt: 'Kansas City Chiefs back-to-back championship graphic',
    name: 'Kansas City',
    type: 'Back-to-back',
    wide: true,
  },
  {
    src: '/graphics/johnson2.webp',
    alt: 'Michigan football player edit',
    name: 'Michigan',
    type: 'Player edit',
  },
  {
    src: '/graphics/naytel.webp',
    alt: 'Naytel Mitchell — Sacramento State commitment graphic',
    name: 'Sacramento State',
    type: 'Commitment',
  },
];
---

<section class="section graphics" id="graphics">
  <div class="container">
    <div class="graphics__head reveal">
      <p class="label">Graphics</p>
      <h2 class="graphics__title">For the game<span class="dot">.</span></h2>
    </div>

    <div class="graphics__grid">
      {graphics.map((g) => (
        <figure class={`g reveal${g.wide ? ' g--wide' : ''}`}>
          <div class="g__frame">
            <img src={g.src} alt={g.alt} loading="lazy" decoding="async" />
          </div>
          <figcaption class="g__cap">
            <span class="g__name">{g.name}</span>
            <span class="label g__type">{g.type}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .graphics__head {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: clamp(2.5rem, 6vh, 4rem);
  }

  .graphics__title {
    font-weight: 600;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    letter-spacing: -0.01em;
    line-height: 1.1;
  }

  .graphics__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2vw, 1.5rem);
  }

  .g {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .g--wide {
    grid-column: 1 / -1;
  }

  .g__frame {
    overflow: hidden;
    border: 1px solid var(--hairline-on-ink);
    aspect-ratio: 6 / 7;
    background: var(--ink);
  }

  .g--wide .g__frame {
    aspect-ratio: 16 / 10;
  }

  .g__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease-settle);
  }

  .g:hover .g__frame img,
  .g:focus-within .g__frame img {
    transform: scale(1.03);
  }

  .g:hover .g__frame,
  .g:focus-within .g__frame {
    border-color: var(--steel);
  }

  .g__cap {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }

  .g__name {
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: -0.005em;
  }

  .g__type {
    color: var(--brass);
    white-space: nowrap;
  }

  @media (max-width: 700px) {
    .graphics__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
